	$(MAKE) $(MAKESILENT) -f CMakeFiles/chronos_core.dir/build.make CMakeFiles/chronos_core.dir/src/vector_index.cpp.i
.PHONY : src/vector_index.cpp.i

src/vector_index.s: src/vector_index.cpp.s
.PHONY : src/vector_index.s

# target to generate assembly for a file
src/vector_index.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/chronos_core.dir/build.make CMakeFiles/chronos_core.dir/src/vector_index.cpp.s
.PHONY : src/vector_index.cpp.s

